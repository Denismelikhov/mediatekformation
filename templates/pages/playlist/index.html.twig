{% extends "basefront.html.twig" %}

{% block body %}
    <h1>Gestion des playlists</h1>

    <p>
        <a href="{{ path('playlist_new') }}">Ajouter une playlist</a>
    </p>

    <table border="1">
        <thead>
            <tr>
                <th>ID</th>
                <th>Nom</th>
                <th>Description</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for playlist in playlists %}
            <tr>
                <td>{{ playlist.id }}</td>
                <td>{{ playlist.name }}</td>
                <td>{{ playlist.description }}</td>
                <td>
                    <a href="{{ path('playlist_edit', {id: playlist.id}) }}">Modifier</a>

                    <form method="post"
                          action="{{ path('playlist_delete', {id: playlist.id}) }}"
                          style="display:inline-block;"
                          onsubmit="return confirm('Supprimer cette playlist ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete_playlist_' ~ playlist.id) }}">
                        <button type="submit">Supprimer</button>
                    </form>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="4">Aucune playlist trouvée.</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <p>
        <a href="{{ path('admin') }}">Retour au back office</a>
    </p>
{% endblock %}
