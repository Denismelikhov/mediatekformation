{% extends "basefront.html.twig" %}

{% block body %}
    <h1>Gestion des formations</h1>

    <p>
        <a href="{{ path('formation_new') }}">Ajouter une formation</a>
    </p>

    <table border="1">
        <thead>
            <tr>
                <th>ID</th>
                <th>Titre</th>
                <th>Date</th>
                <th>Playlist</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for formation in formations %}
            <tr>
                <td>{{ formation.id }}</td>
                <td>{{ formation.title }}</td>
                <td>{{ formation.publishedAtString }}</td>
                <td>
                    {% if formation.playlist %}
                        {{ formation.playlist.name }}
                    {% endif %}
                </td>
                <td>
                    <a href="{{ path('formation_edit', {id: formation.id}) }}">Modifier</a>

                    <form method="post"
                          action="{{ path('formation_delete', {id: formation.id}) }}"
                          style="display:inline-block;"
                          onsubmit="return confirm('Supprimer cette formation ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete_formation_' ~ formation.id) }}">
                        <button type="submit">Supprimer</button>
                    </form>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="5">Aucune formation trouvée.</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <p>
        <a href="{{ path('admin') }}">Retour au back office</a>
    </p>
{% endblock %}
