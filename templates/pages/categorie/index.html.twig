{% extends "basefront.html.twig" %}

{% block body %}
    <h1>Gestion des catégories</h1>

    <p>
        <a href="{{ path('categorie_new') }}">Ajouter une catégorie</a>
    </p>

    <table border="1">
        <thead>
            <tr>
                <th>ID</th>
                <th>Nom</th>
                <th>Actions</th>
            </tr>
        </thead>
        <tbody>
        {% for categorie in categories %}
            <tr>
                <td>{{ categorie.id }}</td>
                <td>{{ categorie.name }}</td>
                <td>
                    <form method="post"
                          action="{{ path('categorie_delete', {id: categorie.id}) }}"
                          style="display:inline-block;"
                          onsubmit="return confirm('Supprimer cette catégorie ?');">
                        <input type="hidden" name="_token" value="{{ csrf_token('delete_categorie_' ~ categorie.id) }}">
                        <button type="submit">Supprimer</button>
                    </form>
                </td>
            </tr>
        {% else %}
            <tr>
                <td colspan="3">Aucune catégorie trouvée.</td>
            </tr>
        {% endfor %}
        </tbody>
    </table>

    <p>
        <a href="{{ path('admin') }}">Retour au back office</a>
    </p>
{% endblock %}
